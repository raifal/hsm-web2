            "TemperatureMeasurementCreate": {
                "properties": {
                    "sensor_address": {
                        "type": "string",
                        "title": "Sensor Address"
                    },
                    "temperature": {
                        "type": "number",
                        "title": "Temperature"
                    },
                    "timestamp": {
                        "type": "string",
                        "format": "date-time",
                        "title": "Timestamp"
                    }
                },
                "type": "object",
                "required": [
                    "sensor_address",
                    "temperature",
                    "timestamp"
