                        "type": "array",
                        "title": "Detail"
                    }
                },
                "type": "object",
                "title": "HTTPValidationError"
            },
            "MeasurementItem": {
                "properties": {
                    "temperature": {
                        "type": "number",
                        "title": "Temperature"
                    },
                    "timestamp": {
                        "type": "string",
                        "format": "date-time",
                        "title": "Timestamp"
                    }
                },
                "type": "object",
                "required": [
                    "temperature",
                    "timestamp"
                ],
                "title": "MeasurementItem"
            },
            "SensorCreate": {
                "properties": {
                    "sensorAddress": {
                        "type": "string",
                        "title": "Sensoraddress"
                    },
                    "active": {
                        "type": "boolean",
                        "title": "Active",
                        "default": true
                    },
                    "color": {
                        "type": "string",
                        "title": "Color",
                        "default": ""
                    },
                    "name": {
                        "type": "string",
                        "title": "Name",
                        "default": ""
                    },
                    "groupName": {
                        "type": "string",
                        "title": "Groupname",
                        "default": ""
                    },
                    "lineType": {
                        "type": "string",
                        "title": "Linetype",
                        "default": "solid"
                    }
                },
                "type": "object",
                "required": [
                    "sensorAddress"
                ],
                "title": "SensorCreate"
            },
            "SensorDayMeasurements": {
                "properties": {
                    "sensor_address": {
                        "type": "string",
                        "title": "Sensor Address"
                    },
                    "measurements": {
                        "items": {
                            "$ref": "#/components/schemas/MeasurementItem"
                        },
                        "type": "array",
                        "title": "Measurements"
