                        "type": "string",
                        "title": "Sensor Address"
                    },
                    "temperature": {
                        "type": "number",
                        "title": "Temperature"
                    },
                    "timestamp": {
                        "type": "string",
                        "format": "date-time",
                        "title": "Timestamp"
                    },
                    "id": {
                        "type": "integer",
                        "title": "Id"
                    }
