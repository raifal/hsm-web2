                "type": "object",
                "required": [
                    "sensor_address",
                    "measurements"
                ],
                "title": "SensorDayMeasurements"
            },
            "SensorRead": {
                "properties": {
                    "sensorAddress": {
                        "type": "string",
                        "title": "Sensoraddress"
                    },
                    "active": {
                        "type": "boolean",
