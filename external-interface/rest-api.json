{
    "openapi": "3.1.0",
    "info": {
        "title": "Temperature Measurements Service",
        "description": "REST API for submitting temperature measurements from sensors",
        "version": "1.0.0"
    },
    "paths": {
        "/": {
            "get": {
                "summary": "Root",
                "description": "Health check endpoint (no authentication required)",
                "operationId": "root__get",
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        }
                    }
                }
            }
        },
        "/api/measurements": {
            "get": {
                "summary": "List Measurements",
                "description": "Retrieve all stored temperature measurements from the database.",
                "operationId": "list_measurements_api_measurements_get",
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "items": {
                                        "$ref": "#/components/schemas/TemperatureMeasurementRead"
                                    },
                                    "type": "array",
                                    "title": "Response List Measurements Api Measurements Get"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "HTTPBasic": []
                    }
                ]
            },
            "post": {
                "summary": "Create Measurement",
                "description": "Submit a temperature measurement from a sensor. Creates sensor if it doesn't exist.",
                "operationId": "create_measurement_api_measurements_post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/TemperatureMeasurementCreate"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/TemperatureMeasurementRead"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "HTTPBasic": []
                    }
                ]
            }
        },
        "/api/measurements/batch": {
            "post": {
                "summary": "Create Measurements Batch",
                "description": "Submit a batch of temperature measurements from one or more sensors. Creates sensors if they don't exist.",
                "operationId": "create_measurements_batch_api_measurements_batch_post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
